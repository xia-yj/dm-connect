{
  "name": "dm-connect-desktop",
  "version": "2.0.6",
  "private": true,
  "description": "DM Connect React + Electron desktop client",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -p tsconfig.json && vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@monaco-editor/react": "4.7.0",
    "lucide-react": "1.24.0",
    "monaco-editor": "0.55.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "jsdom": "29.1.1",
    "typescript": "7.0.2",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "wait-on": "^9.0.4"
  },
  "optionalDependencies": {
    "@rolldown/binding-darwin-arm64": "^1.1.5",
    "@rolldown/binding-win32-x64-msvc": "^1.1.5"
  },
  "build": {
    "appId": "com.dmconnect",
    "productName": "DM Connect",
    "asar": true,
    "directories": {
      "output": "../target/electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "!node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "../target/electron-backend",
        "to": "backend"
      }
    ],
    "mac": {
      "target": "dir",
      "category": "public.app-category.developer-tools",
      "icon": "../target/icon.icns",
      "identity": null,
      "minimumSystemVersion": "12.0"
    },
    "win": {
      "target": "nsis"
    }
  }
}
